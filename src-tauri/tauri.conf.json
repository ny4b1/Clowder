{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clowder",
  "version": "0.1.0",
  "identifier": "com.nyabi.clowder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clowder",
        "width": 1200,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ]
  }
}
